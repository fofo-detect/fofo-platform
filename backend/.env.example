# Supabase
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_PUBLISHABLE_KEY=

# Face search
SERPAPI_KEY=

# YouTube Data API v3 (video candidate search). Free tier: 10,000 units/day,
# a search.list call costs 100 units (~100 searches/day free).
YOUTUBE_API_KEY=

# Claude (risk classification)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# AWS: S3 stores enrollment photos (also the SerpAPI search seed), Rekognition
# does face indexing (index_faces) and matching (compare_faces).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=fofo-face-uploads
AWS_REKOGNITION_COLLECTION_ID=fofo-faces

# Sightengine (deepfake scoring)
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# MSG91 WhatsApp
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_INTEGRATED_NUMBER=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_ANNUAL_PRICE_ID=

# App
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
FACE_MATCH_SIMILARITY_THRESHOLD_THUMBNAIL=80.0
FACE_MATCH_SIMILARITY_THRESHOLD_FULL=90.0
MAX_CANDIDATES_PER_SCAN=59

# Admin dashboard (/admin) - single shared password, required for any admin
# login to succeed (empty means all admin logins are refused).
ADMIN_PASSWORD=

# Automated scan sweep - how often (in hours) every active subscriber is
# scanned automatically with no manual trigger. WARNING: each sweep cycle
# multiplies SerpAPI usage by the number of active subscribers x reference
# photos x search sources - watch /admin/api-usage closely after enabling.
# Disabled by default (fails closed) - must be explicitly set to true.
SCHEDULER_ENABLED=false
SCAN_INTERVAL_HOURS=3
